# moav-client — docker-compose environment overrides.
# Copy to .env (cp .env.example .env) or let the dashboard's Network tab
# manage this for you via /api/exposure.

# Bind addresses for the host ports exposed by docker-compose:
#   127.0.0.1 (default) — only this machine reaches the proxy
#   0.0.0.0             — every device on your LAN (or beyond, if you
#                         port-forward) can reach the proxy
SOCKS5_BIND=127.0.0.1
HTTP_BIND=127.0.0.1
API_BIND=127.0.0.1
UI_BIND=127.0.0.1

# Optional SOCKS5 auth — recommended whenever SOCKS5_BIND is 0.0.0.0.
# Wire these into config.yaml -> proxy.auth or the dashboard writes them
# alongside the bind settings.
# SOCKS5_USERNAME=
# SOCKS5_PASSWORD=

# moav-client tracks the chosen exposure mode here so it can render the
# right control in the dashboard. One of: loopback | lan | public.
MOAV_EXPOSURE=loopback

# Dashboard / API basic auth. Strongly recommended whenever the dashboard
# is reachable from anything other than localhost. Both must be set for
# auth to engage. /api/healthz remains open for liveness checks.
# MOAV_DASHBOARD_USER=admin
# MOAV_DASHBOARD_PASS=


# ---------------------------------------------------------------------------
# Component versions / image overrides
#
# Pin the versions of the bundled components. Changing one of these and running
# `moav-client up` (or `docker compose up -d --build`) rebuilds/re-pulls just
# that piece. The defaults below match what ships with this release.
# ---------------------------------------------------------------------------

# moav-client version stamped into the proxy-core binary + dashboard footer.
# Normally tracks the VERSION file; override only when building a custom tag.
# MOAV_VERSION=1.2.0

# Xray-core (official XTLS release, built by sidecars/xray/Dockerfile). Use a
# release tag from https://github.com/XTLS/Xray-core/releases (pre-releases OK).
# XRAY_VERSION=v26.5.9

# Pulled images — override the whole ref (repo:tag) to pin or swap registries.
# IMAGE_SINGBOX=ghcr.io/sagernet/sing-box:v1.13.12
# IMAGE_TOR=peterdavehello/tor-socks-proxy:latest
# IMAGE_CADDY=caddy:2
