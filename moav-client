#!/usr/bin/env bash
# =============================================================================
#  moav-client — manage your MoaV local client (the proxy-core + web-ui +
#  sing-box / xray stack). Run `moav-client help` for commands.
#
#  Run from the install directory, or symlink into PATH:
#    ln -sf "$PWD/moav-client" /usr/local/bin/moav-client
#
#  Repo:  https://github.com/MotherofallVPNs/moav-client
#  Site:  https://moav.sh
# =============================================================================
set -euo pipefail

GITHUB_URL="https://github.com/MotherofallVPNs/moav-client"
SITE_URL="https://moav.sh"

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# If the script was symlinked into PATH, prefer the env var or fall back to
# its own directory as the install root.
ROOT="${MOAV_DIR:-$SCRIPT_DIR}"
cd "$ROOT"

if [[ -t 1 ]]; then
  CR=$'\033[0m'; BLD=$'\033[1m'; DIM=$'\033[2m'
  RED=$'\033[31m'; GRN=$'\033[32m'; YLW=$'\033[33m'; BLU=$'\033[34m'; CYN=$'\033[36m'
else
  CR= BLD= DIM= RED= GRN= YLW= BLU= CYN=
fi

API="http://localhost:8088"
DASHBOARD="http://localhost:3001"

SIDECAR_KINDS=(masterdns amneziawg psiphon trusttunnel tor)

# Read a value from .env (last wins; strips quotes). Empty if absent.
env_val() {
  local key="$1" file="$ROOT/.env" v=""
  [[ -f "$file" ]] && v=$(grep -E "^${key}=" "$file" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '"' | tr -d "'")
  echo "$v"
}

# ASCII logo + version + links. Used by `help` and `version`.
print_banner() {
  local ver sha
  ver=$(cat "$ROOT/VERSION" 2>/dev/null || echo "?")
  sha=$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || echo "?")
  printf '%s' "$CYN$BLD"
  cat <<'ART'
  ███╗   ███╗ ██████╗  █████╗ ██╗   ██╗
  ████╗ ████║██╔═══██╗██╔══██╗██║   ██║
  ██╔████╔██║██║   ██║███████║██║   ██║
  ██║╚██╔╝██║██║   ██║██╔══██║╚██╗ ██╔╝
  ██║ ╚═╝ ██║╚██████╔╝██║  ██║ ╚████╔╝
  ╚═╝     ╚═╝ ╚═════╝ ╚═╝  ╚═╝  ╚═══╝
ART
  printf '%s' "$CR"
  printf '  %sMother of all VPNs — local client%s\n\n' "$DIM" "$CR"
  printf '  %sversion%s %sv%s%s %s(%s)%s\n' "$DIM" "$CR" "$GRN" "$ver" "$CR" "$DIM" "$sha" "$CR"
  printf '  %srepo%s    %s%s%s\n' "$DIM" "$CR" "$BLU" "$GITHUB_URL" "$CR"
  printf '  %ssite%s    %s%s%s\n' "$DIM" "$CR" "$BLU" "$SITE_URL" "$CR"
}

usage() {
  print_banner
  cat <<USAGE

  ${BLD}Usage:${CR} moav-client <command> [options]

  ${BLD}Stack${CR}
    up [--profile <n>...]      start / (re)start the stack
    down                       stop the stack
    restart                    rebuild + restart proxy-core + web-ui
    status                     formatted status of every service + access URLs
    info                       just the dashboard / proxy / API URLs
    logs [-f] [service]        tail container logs

  ${BLD}Endpoints${CR}
    probe                      trigger an immediate latency probe
    stats                      per-endpoint counters (JSON)

  ${BLD}Sidecars & config${CR}
    sidecar list               which optional sidecars are running
    sidecar add <name>         enable + build + start a sidecar
    sidecar remove <name>      stop + disable a sidecar
    install                    re-run the install wizard (add/remove sidecars)
    expose <mode>              network reach: loopback | lan | public

  ${BLD}Maintenance${CR}
    update [-b <branch>]       git pull (optionally switch branch) + rebuild
    open                       open the dashboard in a browser
    version                    print version, commit & links
USAGE
}

compose() { docker compose "$@"; }

# Print the access URLs for each service, derived from the saved exposure mode
# in .env. Loopback → localhost; lan/public → this host's primary IP.
cmd_info() {
  local mode host dashUser socksUser
  mode=$(env_val MOAV_EXPOSURE); mode="${mode:-loopback}"
  if [[ "$mode" == "loopback" ]]; then
    host="localhost"
  else
    host="$(lan_ip)"; host="${host:-<this-host-ip>}"
  fi
  dashUser=$(env_val MOAV_DASHBOARD_USER)
  socksUser=$(env_val SOCKS5_USERNAME)
  echo "${BLD}Access${CR} ${DIM}(exposure: ${mode})${CR}"
  printf '  %-13s %s%s%s%s\n' "Dashboard"   "$BLU" "http://${host}:3001"      "$CR" "${dashUser:+  ${DIM}login: ${dashUser}${CR}}"
  printf '  %-13s %s%s%s%s\n' "SOCKS5"       "$BLU" "socks5h://${host}:1080"   "$CR" "${socksUser:+  ${DIM}auth: ${socksUser}${CR}}"
  printf '  %-13s %s%s%s\n'   "HTTP proxy"   "$BLU" "http://${host}:8081"      "$CR"
  printf '  %-13s %s%s%s\n'   "REST/WS API"  "$BLU" "http://${host}:8088"      "$CR"
  if [[ "$mode" != "loopback" && -z "$dashUser" ]]; then
    echo "  ${YLW}! no dashboard login set while exposed — set one:  moav-client expose ${mode} --password <pw>${CR}"
  fi
}

# Build "--profile X --profile Y" args for currently-enabled sidecars
# (those whose config.yaml block says enabled: true).
enabled_profiles() {
  python3 - <<'PY'
import re, pathlib
src = pathlib.Path("config.yaml").read_text() if pathlib.Path("config.yaml").exists() else ""
out = []
for kind in ("masterdns","amneziawg","psiphon","trusttunnel","tor"):
    m = re.search(r'^\s*' + kind + r':\s*\n(?:\s*#.*\n)*?\s*enabled:\s*(true|false)', src, re.MULTILINE)
    if m and m.group(1) == "true":
        out.append(kind)
print(" ".join(out))
PY
}

profile_args() {
  local args=()
  for k in $(enabled_profiles); do args+=(--profile "$k"); done
  printf '%s\n' "${args[@]:-}"
}

cmd_up() {
  local args=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && args+=("$line")
  done < <(profile_args)
  echo "${CYN}→ starting (${args[*]:-no sidecars})${CR}"
  compose "${args[@]:-}" up -d "$@"
  cmd_status
  # Auto-open the dashboard unless suppressed.
  if [[ -z "${MOAV_NO_OPEN:-}" ]]; then
    sleep 1
    cmd_open >/dev/null 2>&1 || true
  fi
}

cmd_down() {
  local args=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && args+=("$line")
  done < <(profile_args)
  echo "${CYN}→ stopping${CR}"
  compose "${args[@]:-}" down "$@"
}

cmd_restart() {
  echo "${CYN}→ rebuilding + restarting proxy-core + web-ui${CR}"
  compose build proxy-core web-ui
  compose up -d --force-recreate proxy-core web-ui
  cmd_status
}

cmd_status() {
  local args=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && args+=("$line")
  done < <(profile_args)

  echo "${BLD}Services${CR}"
  # Clean Service + Status table instead of the default long container names.
  compose "${args[@]:-}" ps --format 'table {{.Service}}\t{{.Status}}' 2>/dev/null \
    || compose "${args[@]:-}" ps

  # Endpoint health summary from the API (best-effort — proxy-core may be down).
  local eps
  if eps=$(curl -fsS --max-time 2 "$API/api/endpoints" 2>/dev/null); then
    local total ok strat
    total=$(printf '%s' "$eps" | grep -o '"ID"' | wc -l | tr -d ' ')
    ok=$(printf '%s' "$eps" | grep -o '"Status":"ok"' | wc -l | tr -d ' ')
    strat=$(curl -fsS --max-time 2 "$API/api/stats" 2>/dev/null | sed -n 's/.*"strategy":"\([^"]*\)".*/\1/p')
    echo ""
    echo "${BLD}Endpoints${CR}  ${GRN}${ok}${CR}/${total} healthy${strat:+   ${DIM}strategy: ${strat}${CR}}"
  fi

  echo ""
  cmd_info
}

cmd_logs() {
  local args=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && args+=("$line")
  done < <(profile_args)
  compose "${args[@]:-}" logs --tail=80 "$@"
}

cmd_probe() {
  curl -fsS -X POST "$API/api/probe" >/dev/null && echo "${GRN}✓ probing all endpoints${CR}"
}

cmd_stats() {
  if command -v jq >/dev/null 2>&1; then
    curl -fsS "$API/api/stats" | jq .
  else
    curl -fsS "$API/api/stats" | python3 -m json.tool
  fi
}

is_valid_sidecar() {
  local s="$1"
  for k in "${SIDECAR_KINDS[@]}"; do [[ "$s" == "$k" ]] && return 0; done
  return 1
}

cmd_sidecar() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    list)
      for kind in "${SIDECAR_KINDS[@]}"; do
        if docker ps --format '{{.Names}}' | grep -q "moav-client-${kind}-1"; then
          echo "${GRN}● $kind${CR}    running"
        else
          echo "${DIM}○ $kind${CR}    stopped"
        fi
      done
      ;;
    add)
      local s="${1:?usage: moav-client sidecar add <name>}"
      is_valid_sidecar "$s" || { echo "${RED}unknown sidecar: $s${CR} (valid: ${SIDECAR_KINDS[*]})"; exit 1; }
      python3 - "$s" <<'PY'
import re, pathlib, sys
kind = sys.argv[1]
p = pathlib.Path("config.yaml")
src = p.read_text()
pat = re.compile(r'(^\s*' + re.escape(kind) + r':\s*\n(?:\s*#.*\n)*?\s*)enabled:\s*\w+', re.MULTILINE)
new, n = pat.subn(r'\1enabled: true', src)
if n: p.write_text(new); print(f"config.yaml: {kind} enabled")
PY
      compose --profile "$s" build "$s"
      compose --profile "$s" up -d "$s"
      compose restart proxy-core
      cmd_status
      ;;
    remove)
      local s="${1:?usage: moav-client sidecar remove <name>}"
      is_valid_sidecar "$s" || { echo "${RED}unknown sidecar: $s${CR}"; exit 1; }
      compose --profile "$s" stop "$s" || true
      compose --profile "$s" rm -f "$s" || true
      python3 - "$s" <<'PY'
import re, pathlib, sys
kind = sys.argv[1]
p = pathlib.Path("config.yaml")
src = p.read_text()
pat = re.compile(r'(^\s*' + re.escape(kind) + r':\s*\n(?:\s*#.*\n)*?\s*)enabled:\s*\w+', re.MULTILINE)
new, n = pat.subn(r'\1enabled: false', src)
if n: p.write_text(new); print(f"config.yaml: {kind} disabled")
PY
      compose restart proxy-core
      ;;
    *)
      echo "${RED}usage: moav-client sidecar {list|add <name>|remove <name>}${CR}"
      echo "        valid: ${SIDECAR_KINDS[*]}"
      exit 1
      ;;
  esac
}

cmd_open() {
  local opener=
  if command -v xdg-open >/dev/null 2>&1; then opener=xdg-open
  elif command -v open >/dev/null 2>&1; then opener=open
  fi
  if [[ -n "$opener" ]]; then
    "$opener" "$DASHBOARD"
  else
    echo "open this in your browser: ${BLU}$DASHBOARD${CR}"
  fi
}

# Update the install: optionally switch branch (-b/--branch, like `moav`), pull,
# then rebuild + recreate the whole stack (including xray + enabled sidecars).
cmd_update() {
  local target_branch=""
  while (( $# > 0 )); do
    case "$1" in
      -b|--branch) target_branch="${2:?-b needs a branch name}"; shift 2 ;;
      -h|--help)
        echo "usage: moav-client update [-b <branch>]"
        echo "  -b, --branch   switch to and pull this branch (e.g. main, dev)"
        return 0 ;;
      *) echo "${RED}unknown option: $1${CR}  (try: moav-client update -b <branch>)"; return 1 ;;
    esac
  done

  if [[ ! -d "$ROOT/.git" ]]; then
    echo "${RED}$ROOT isn't a git checkout — can't update${CR}"; exit 1
  fi

  local cur; cur=$(git -C "$ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
  local sha; sha=$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || echo "?")
  echo "${DIM}current: ${cur} @ ${sha}${CR}"
  git -C "$ROOT" fetch --all --prune --quiet 2>/dev/null || echo "${YLW}! fetch failed — using local refs${CR}"

  if [[ -n "$target_branch" && "$target_branch" != "$cur" ]]; then
    if ! git -C "$ROOT" show-ref --verify --quiet "refs/heads/$target_branch" 2>/dev/null \
       && ! git -C "$ROOT" show-ref --verify --quiet "refs/remotes/origin/$target_branch" 2>/dev/null; then
      echo "${RED}branch '$target_branch' not found.${CR} available:"
      git -C "$ROOT" branch -a | sed 's/^/  /' | head -15
      exit 1
    fi
    echo "${CYN}→ switching to branch ${target_branch}${CR}"
    git -C "$ROOT" checkout "$target_branch" || { echo "${RED}checkout failed${CR}"; exit 1; }
    cur="$target_branch"
  fi

  echo "${CYN}→ pulling ${cur}${CR}"
  git -C "$ROOT" pull --ff-only origin "$cur" 2>/dev/null || git -C "$ROOT" pull || {
    echo "${RED}pull failed — resolve local changes (git -C $ROOT status) and retry${CR}"; exit 1
  }
  echo "${GRN}✓ now at $(git -C "$ROOT" rev-parse --short HEAD) (branch: ${cur})${CR}"

  # Rebuild + recreate everything (proxy-core/web-ui/xray + enabled sidecars).
  local args=()
  while IFS= read -r line; do [[ -n "$line" ]] && args+=("$line"); done < <(profile_args)
  echo "${CYN}→ rebuilding + restarting${CR}"
  compose "${args[@]:-}" up -d --build
  echo ""
  cmd_status
}

cmd_version() {
  print_banner
  echo ""
  echo "  ${DIM}install dir: ${ROOT}${CR}"
}

# Re-run the install wizard against this install dir (add/remove sidecars,
# rebuild, re-up). install.sh handles the existing repo + pre-checks the
# sidecars already enabled in config.yaml.
cmd_install() {
  if [[ ! -f "$ROOT/install.sh" ]]; then
    echo "${RED}install.sh not found in $ROOT${CR}"; exit 1
  fi
  MOAV_DIR="$ROOT" bash "$ROOT/install.sh" --dir "$ROOT" "$@"
}

# --- .env helpers (mirror proxy-core handleExposure / install.sh) -----------
set_env_kv() {
  local key="$1" val="$2" file="$ROOT/.env"
  touch "$file"
  if grep -qE "^${key}=" "$file" 2>/dev/null; then
    sed -i.bak -E "s|^${key}=.*|${key}=${val}|" "$file" && rm -f "${file}.bak"
  else
    printf '%s=%s\n' "$key" "$val" >>"$file"
  fi
}

lan_ip() {
  local ip=""
  if command -v ip >/dev/null 2>&1; then
    ip=$(ip -4 route get 1.1.1.1 2>/dev/null | sed -n 's/.* src \([0-9.]*\).*/\1/p' | head -1)
  fi
  [[ -z "$ip" ]] && command -v hostname >/dev/null 2>&1 && ip=$(hostname -I 2>/dev/null | awk '{print $1}')
  [[ -z "$ip" ]] && command -v ipconfig >/dev/null 2>&1 && ip=$(ipconfig getifaddr en0 2>/dev/null)
  echo "$ip"
}

# Change network reach. loopback = 127.0.0.1 (this machine only); lan/public =
# 0.0.0.0 (every device that can route to this host). Writes the same .env keys
# the dashboard's Network exposure setting uses, then recreates the containers.
cmd_expose() {
  local mode="${1:-}"; shift || true
  local user="" pass=""
  while (( $# > 0 )); do
    case "$1" in
      --user)     user="$2"; shift ;;
      --password) pass="$2"; shift ;;
      *) echo "${RED}unknown flag: $1${CR}"; exit 1 ;;
    esac
    shift
  done
  local bind
  case "$mode" in
    loopback) bind="127.0.0.1" ;;
    lan|public) bind="0.0.0.0" ;;
    *) echo "${RED}usage: moav-client expose <loopback|lan|public> [--user U --password P]${CR}"; exit 1 ;;
  esac
  local k
  for k in SOCKS5_BIND HTTP_BIND API_BIND UI_BIND; do set_env_kv "$k" "$bind"; done
  set_env_kv "MOAV_EXPOSURE" "$mode"
  if [[ -n "$pass" ]]; then
    set_env_kv "MOAV_DASHBOARD_USER" "${user:-admin}"
    set_env_kv "MOAV_DASHBOARD_PASS" "$pass"
    echo "${GRN}✓ dashboard auth set for '${user:-admin}'${CR}"
  fi
  if [[ "$mode" != "loopback" && -z "$pass" ]]; then
    echo "${YLW}! exposing to the network with no dashboard password — set one with --password, or in Settings → Network exposure${CR}"
  fi
  echo "${CYN}→ applying exposure=${mode} (bind ${bind}) — recreating proxy-core + web-ui${CR}"
  compose up -d --force-recreate proxy-core web-ui
  if [[ "$mode" == "loopback" ]]; then
    echo "${GRN}✓ now on localhost only — http://localhost:3001${CR}"
  else
    local ip; ip="$(lan_ip)"
    echo "${GRN}✓ now reachable at http://${ip:-<this-host-ip>}:3001  (SOCKS5 ${ip:-<this-host-ip>}:1080)${CR}"
  fi
}

case "${1:-help}" in
  up|start)     shift; cmd_up "$@" ;;
  down|stop)    shift; cmd_down "$@" ;;
  restart)      cmd_restart ;;
  status|ps)    cmd_status ;;
  info|urls)    cmd_info ;;
  logs|log)     shift; cmd_logs "$@" ;;
  probe)        cmd_probe ;;
  stats)        cmd_stats ;;
  sidecar)      shift; cmd_sidecar "$@" ;;
  install|wizard) shift; cmd_install "$@" ;;
  expose)       shift; cmd_expose "$@" ;;
  open)         cmd_open ;;
  update)       cmd_update ;;
  version)      cmd_version ;;
  help|--help|-h|"") usage ;;
  *)            echo "${RED}unknown command: $1${CR}"; usage; exit 1 ;;
esac
