FROM node:20-alpine AS builder
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install
COPY . .
RUN npm run build

# nginx:alpine is ~50MB vs node + vite preview at ~340MB. Vite preview was
# only needed during dev; production just serves the static dist.
FROM nginx:1.27-alpine
# htpasswd (apache2-utils) for generating dashboard basic-auth credentials.
RUN apk add --no-cache apache2-utils
COPY --from=builder /app/dist /usr/share/nginx/html
# Custom server block: listens on 3000 (compose contract), reverse-proxies
# /api + /api/ws to proxy-core (single origin), sets cache headers, and includes
# the optional dashboard basic-auth generated by the entrypoint hook below.
COPY nginx.conf /etc/nginx/conf.d/default.conf
# Default auth include (overwritten on start by 40-moav-auth.sh); ensures the
# `include` in nginx.conf resolves even if the hook is skipped.
RUN echo "auth_basic off;" > /etc/nginx/moav-auth.conf
COPY 40-moav-auth.sh /docker-entrypoint.d/40-moav-auth.sh
RUN chmod +x /docker-entrypoint.d/40-moav-auth.sh
EXPOSE 3000
